@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap');

:root {
    --navy: #0A0F1C;
    --accent: #0F766E;
    --accent-dark: #115E59;
    --surface: #FAFAF9;
}

body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
}

.heading-serif {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    letter-spacing: -0.035em;
}

.university-nav {
    background: #ffffff;
    border-bottom: 1px solid #E5E7EB;
    box-shadow: 0 1px 0 0 rgba(10, 15, 28, 0.03);
}

.section-header {
    font-size: 2.35rem;
    line-height: 2.55rem;
    font-weight: 700;
    color: #0A0F1C;
    letter-spacing: -0.045em;
}

.academic-card {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.2s ease;
    border: 1px solid #E5E7EB;
    background: white;
}

.academic-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 50px -12px rgb(10 15 28 / 0.12),
                0 10px 10px -6px rgb(10 15 28 / 0.08);
    border-color: #D1D5DB;
}

.nav-link {
    color: #4B5563;
    font-weight: 500;
    transition: color 0.15s ease;
    position: relative;
}

.nav-link:hover {
    color: #0A0F1C;
}

.hero-overlay {
    background: linear-gradient(
        to bottom,
        rgba(10, 15, 28, 0.68) 0%,
        rgba(10, 15, 28, 0.78) 50%,
        rgba(10, 15, 28, 0.88) 100%
    );
}

.stat-number {
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
}

.testimonial {
    position: relative;
}

.testimonial::before {
    content: '\201C';
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 8rem;
    line-height: 0.7;
    color: #E5E7EB;
    position: absolute;
    top: -2.1rem;
    left: 1.6rem;
    z-index: 0;
    font-weight: 700;
    opacity: 0.9;
}

.formal-button {
    background-color: #0A0F1C;
    color: white;
    font-weight: 600;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 1px 2px 0 rgb(10 15 28 / 0.08);
}

.formal-button:hover {
    background-color: #1F2937;
    transform: translateY(-1px);
    box-shadow: 0 10px 15px -3px rgb(10 15 28 / 0.15);
}

.accent-button {
    background-color: #0F766E;
    color: white;
    font-weight: 600;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 6px -1px rgb(15 118 110 / 0.25);
}

.accent-button:hover {
    background-color: #115E59;
    transform: translateY(-1.5px);
    box-shadow: 0 20px 25px -5px rgb(15 118 110 / 0.3);
}

.accent-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
}

.campus-card {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 15px -3px rgb(10 15 28 / 0.08),
                0 4px 6px -4px rgb(10 15 28 / 0.08);
}

.campus-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 25px 50px -12px rgb(10 15 28 / 0.15);
}

.program-badge {
    background-color: #CCFBF1;
    color: #0F766E;
    font-size: 0.6875rem;
    padding: 0.1rem 0.7rem;
    border-radius: 9999px;
    font-weight: 700;
    letter-spacing: 0.02em;
}

.premium-shadow {
    box-shadow: 0 10px 15px -3px rgb(10 15 28 / 0.08),
                0 4px 6px -4px rgb(10 15 28 / 0.08);
}

/* Scroll reveal animations */
.reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}

.reveal.visible {
    opacity: 1;
    transform: translateY(0);
}

.reveal-delay-1 { transition-delay: 80ms; }
.reveal-delay-2 { transition-delay: 160ms; }
.reveal-delay-3 { transition-delay: 240ms; }

.section-divider {
    height: 1px;
    background: linear-gradient(to right, transparent, #E5E7EB, transparent);
}

.nav-active:after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 2px;
    background: #0F766E;
}

.interactive-card {
    cursor: pointer;
}

.interactive-card:active {
    transform: scale(0.985);
}

.field-error {
    border-color: #DC2626 !important;
}

.error-text {
    color: #DC2626;
    font-size: 0.75rem;
    margin-top: 0.35rem;
    font-weight: 500;
}

.modal {
    animation: modalEnter 0.2s cubic-bezier(0.32, 0.72, 0, 1);
}

@keyframes modalEnter {
    from {
        opacity: 0;
        transform: translateY(20px) scale(0.985);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.subtle-grid {
    background-image:
        linear-gradient(rgba(10, 15, 28, 0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(10, 15, 28, 0.025) 1px, transparent 1px);
    background-size: 28px 28px;
}

/* Respect users who ask for less motion. Was missing entirely before. */
@media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.001ms !important;
        scroll-behavior: auto !important;
    }

    .reveal {
        opacity: 1;
        transform: none;
    }
}

/* Visible keyboard focus for accessibility. */
a:focus-visible,
button:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible {
    outline: 2px solid #0F766E;
    outline-offset: 2px;
}
